# ============================================================================
# Polymarket Copy-Trader — configuration
# Copy this file to `.env` and fill in values. `.env` is git-ignored.
# ============================================================================

# ── EXECUTION MODE ────────────────────────────────────────────────────────────
# DEMO_MODE = fully offline synthetic data, no wallet, no network.
DEMO_MODE=false

# When false (default) the bot reads the LIVE leaderboard but never places
# real orders. Set to true only after verifying the wallet with check_wallet.
LIVE_TRADING=false

# How often the copy loop runs (minutes).
POLL_INTERVAL_MIN=1
# Re-rank traders at most this often (minutes).
LEADERBOARD_REFRESH_MIN=15

# ── WALLET (live trading only) ────────────────────────────────────────────────
# Private key of your SIGNING wallet (0x-prefixed hex). NEVER share or commit.
PRIVATE_KEY=
# Address that HOLDS your USDC on Polygon (your Polymarket deposit address).
WALLET_ADDRESS=
# Signature type — MUST match your wallet:
#   0 = self-custody EOA / seed phrase   1 = email/Magic   2 = browser proxy
SIGNATURE_TYPE=0

# ── TRADER SELECTION ──────────────────────────────────────────────────────────
TOP_N=10
LEADERBOARD_WINDOW=MONTH
LEADERBOARD_CATEGORY=OVERALL
TRADER_ALLOWLIST=
TRADER_BLOCKLIST=

# ── SIGNAL ENGINE (consensus-based) ──────────────────────────────────────────
# Minimum unique traders that must independently enter the same market/outcome
# to trigger a trade. Higher = fewer, higher-quality trades.
MIN_CONSENSUS_COUNT=2
# Minimum composite confidence score (0–1) to execute a signal.
MIN_SIGNAL_CONFIDENCE=0.55
# Look-back window used to detect consensus (minutes).
SIGNAL_WINDOW_MIN=30
# Minimum minutes between re-entering the same market (cooldown).
SIGNAL_COOLDOWN_MIN=60

# ── POSITION SIZING (fractional Kelly) ───────────────────────────────────────
# Fraction of full Kelly to use (0.25 = conservative quarter-Kelly).
KELLY_FRACTION=0.25
# Hard cap: never bet more than this fraction of bankroll per trade.
MAX_KELLY_BET_PCT=0.05
# Apply this multiplier on top of Kelly (1.0 = no change).
COPY_RATIO=1.0
# Per-trade hard clamps (applied after Kelly).
MIN_ORDER_USD=1.0
MAX_PER_TRADE_USD=25.0
MAX_DAILY_SPEND_USD=100.0
MAX_OPEN_POSITIONS=25
# Max fraction of bankroll in any single market.
MAX_EXPOSURE_PER_MARKET_PCT=0.15
# Max fraction of bankroll following any single tracked trader.
MAX_EXPOSURE_PER_TRADER_PCT=0.30

# ── ENTRY FILTERS ─────────────────────────────────────────────────────────────
# Skip if current price moved more than this fraction from trader's fill.
MAX_SLIPPAGE_PCT=0.03
# Don't enter a position above this price (little upside remaining).
MAX_ENTRY_PRICE=0.97
# Ignore source trades smaller than this USD.
MIN_TRADE_USD=5.0
COPY_BUYS_ONLY=true
# Maximum allowed spread as a fraction of price (reject illiquid markets).
MAX_SPREAD_PCT=0.08

# ── RISK MANAGEMENT ───────────────────────────────────────────────────────────
# Halt trading if today's equity drops more than this fraction from start-of-day.
DAILY_LOSS_LIMIT_PCT=0.05
# Halt if this week's equity drops more than this fraction from start-of-week.
WEEKLY_LOSS_LIMIT_PCT=0.10
# Activate circuit breaker after this many consecutive losing trades (0 = off).
CIRCUIT_BREAKER_LOSSES=5
# Wait this many minutes after any losing trade before the next one (0 = off).
COOLDOWN_AFTER_LOSS_MIN=0

# ── PROTECTIVE EXITS ──────────────────────────────────────────────────────────
ENABLE_AUTO_EXITS=true
# Sell when a position is up this fraction (0.5 = +50%).
TAKE_PROFIT_PCT=0.5
# Sell when a position is down this fraction (0.3 = -30%).
STOP_LOSS_PCT=0.3
# Also sell when a copied trader sells that market.
MIRROR_EXITS=true
# Trailing stop: sell if price falls this far below its peak (0 = off).
TRAILING_STOP_PCT=0.0
# Move stop to break-even once position is up 50% of take-profit threshold.
BREAK_EVEN_STOP=false

# ── PAPER MODE ────────────────────────────────────────────────────────────────
PAPER_BANKROLL=1000.0
# On first sight of a trader, look back this many minutes (0 = only new trades).
INITIAL_LOOKBACK_MIN=0

# ── ENDPOINTS (correct defaults — only change if Polymarket updates them) ────
DATA_API_URL=https://data-api.polymarket.com
GAMMA_API_URL=https://gamma-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com
CHAIN_ID=137

DATABASE_URL=sqlite:///./autotrader.db
